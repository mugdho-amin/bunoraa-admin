{
  "name": "bunoraa-admin-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Bunoraa Admin v2 - Refine-powered enterprise admin workspace",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 next build",
    "build:analyze": "cross-env ANALYZE=true NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "next start --port 3001",
    "start:dev": "next start --port 3001",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "keywords": [
    "bunoraa",
    "refine",
    "nextjs",
    "admin"
  ],
  "engines": {
    "node": "24.x"
  },
  "author": "",
  "license": "ISC",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@refinedev/antd": "^6.0.3",
    "@refinedev/core": "^5.0.12",
    "@refinedev/nextjs-router": "^7.0.5",
    "@tanstack/react-query": "^5.100.10",
    "antd": "^5.29.3",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "qs": "^6.15.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "path-to-regexp": "8.4.2",
    "postcss": "8.5.15"
  }
}
