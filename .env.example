# ── Bunoraa Admin environment template ──
# Production URLs (https://api.bunoraa.com) are built-in as hardcoded defaults.
# This file is only needed for local development overrides.

# ── Local development ──
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_ADMIN_WS_URL=ws://127.0.0.1:8000/ws/admin/updates/
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3001

# Logging Level (debug | info | warn | error)
NEXT_PUBLIC_LOG_LEVEL=info

# Telemetry
NEXT_TELEMETRY_DISABLED=1

# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  CRITICAL: Vercel Deployment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# These MUST be set in Vercel Dashboard (Project Settings → Environment Variables)
# for the admin panel to connect to the Django backend on Hugging Face Spaces.
#
# ── Production (scope: Production) ────────────────────────────────────────────
#   NEXT_PUBLIC_API_BASE_URL=https://musaddikul-bunoraa-backend.hf.space/api/v1
#   NEXT_PUBLIC_ADMIN_WS_URL=wss://musaddikul-bunoraa-backend.hf.space/ws/admin/updates/
#   NEXT_PUBLIC_ADMIN_APP_URL=https://bunoraa-admin-v2.vercel.app
#   NEXT_PUBLIC_LOG_LEVEL=warn
#
#   NOTE: If you set up a custom domain (e.g., api.bunoraa.com) via Cloudflare DNS
#   pointing to the Hugging Face Space, replace the URLs accordingly:
#   NEXT_PUBLIC_API_BASE_URL=https://api.bunoraa.com/api/v1
#   NEXT_PUBLIC_ADMIN_WS_URL=wss://api.bunoraa.com/ws/admin/updates/
#
# ── Preview (scope: Preview) ──────────────────────────────────────────────────
#   NEXT_PUBLIC_API_BASE_URL=https://musaddikul-bunoraa-backend.hf.space/api/v1
#   NEXT_PUBLIC_ADMIN_WS_URL=wss://musaddikul-bunoraa-backend.hf.space/ws/admin/updates/
#   NEXT_PUBLIC_ADMIN_APP_URL=https://bunoraa-admin-v2-git-{branch}-username.vercel.app
#   NEXT_PUBLIC_LOG_LEVEL=info
#
# ── Prerequisites for production connectivity ─────────────────────────────────
# 1. Cloudflare DNS: CNAME record "api" → musaddikul-bunoraa-backend.hf.space (proxy ON)
# 2. Cloudflare SSL/TLS: Set to "Full" or "Full (strict)"
# 3. Hugging Face Space env vars: ALLOW_OPEN_ADMIN=true (to disable IP whitelist)
# 4. Django backend already includes *.vercel.app and api.bunoraa.com in CORS/ALLOWED_HOSTS
# ─────────────────────────────────────────────────────────────────────────────
